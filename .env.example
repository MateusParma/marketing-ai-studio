# Copie este arquivo para .env e preencha com suas chaves
# =====================================================

# OBRIGATÓRIA - Claude API (para texto/copy/análise)
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui

# OPCIONAL - Google Gemini API (para gerar imagens com NanoBanana)
# Obtenha GRÁTIS em: https://aistudio.google.com/apikey
# Gera até ~500 imagens/dia grátis!
GEMINI_API_KEY=sua_chave_gemini_aqui

# OPCIONAL - OpenAI API (fallback: gera imagens com DALL-E 3)
# Obtenha em: https://platform.openai.com/api-keys
# Custo: ~$0.04 por imagem
OPENAI_API_KEY=sua_chave_openai_aqui

# Porta do servidor
PORT=3002

# OPCIONAL - Meta (Instagram + Facebook)
# Crie app em: https://developers.facebook.com
META_APP_ID=
META_APP_SECRET=
